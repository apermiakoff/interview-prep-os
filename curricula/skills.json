  "skills": [
    {"id": "dp", "title": "Dynamic programming", "kind": "concept", "parent": null, "description": "Define subproblem state precisely, then derive transitions."},
    {"id": "dp/knapsack", "title": "Subset-sum & knapsack DP", "kind": "technique", "parent": "dp", "description": "Reachable-sum states over take-or-skip decisions."},
    {"id": "dp/bitmask", "title": "Bitmask DP", "kind": "technique", "parent": "dp", "description": "Sets of elements encoded as masks; transitions enumerate submasks or single bits."},
    {"id": "dp/interval", "title": "Interval / subsegment DP", "kind": "technique", "parent": "dp", "description": "State is a contiguous range; answer combines split points, often processed by increasing length."},
    {"id": "dp/string", "title": "String DP & edit distances", "kind": "technique", "parent": "dp", "description": "Two-index alignment states over strings: match, edit, count, or partition."},
    {"id": "dp/sequence", "title": "Subsequence & LIS DP", "kind": "technique", "parent": "dp", "description": "Order-preserving subsequence states, including patience-sorting accelerations."},
    {"id": "dp/state-machine", "title": "State-machine DP", "kind": "technique", "parent": "dp", "description": "A small explicit mode set (holding, sold, transactions left) multiplies the position state."},
    {"id": "dp/tree", "title": "Tree DP", "kind": "technique", "parent": "dp", "description": "Post-order states per node; combine child summaries under an invariant."},
    {"id": "dp/grid", "title": "Grid path DP", "kind": "technique", "parent": "dp", "description": "Row/column position states with obstacle or cost transitions."},
    {"id": "trie/prefix-tree", "title": "Trie construction & queries", "kind": "technique", "parent": "trie/trees", "description": "Prefix trees for insert/search/wildcard/weighted-prefix queries, including bitwise tries."},
    {"id": "strings/prefix-function", "title": "KMP / prefix function", "kind": "technique", "parent": null, "description": "Border arrays and failure links for prefix-suffix structure."},
    {"id": "bitwise/masks", "title": "Bit manipulation & masks", "kind": "concept", "parent": null, "description": "Bits as sets: iterate, test, and combine masks confidently."},
    {"id": "greedy/exchange", "title": "Exchange-argument greedy", "kind": "technique", "parent": "greedy/heaps", "description": "Prove a local choice safe by exchanging it into any optimal solution."},
    {"id": "stack/monotonic", "title": "Monotonic stack", "kind": "technique", "parent": "search/monotonic", "description": "Maintain an ordered frontier; pop while the invariant would break."},
    {"id": "search/binary-answer", "title": "Binary search on the answer", "kind": "technique", "parent": "search/monotonic", "description": "Monotone feasibility predicate over the answer space."},
    {"id": "backtracking/pruning", "title": "Backtracking with pruning", "kind": "technique", "parent": "backtracking/decision-tree", "description": "Ordering, symmetry-breaking, and bound pruning to keep search feasible."},
    {"id": "graph/mst", "title": "Minimum spanning trees", "kind": "technique", "parent": "graph/connectivity-paths", "description": "Kruskal/Prim exchange arguments; criticality via forced inclusion/exclusion."},
    {"id": "trees/recursion", "title": "Recursive tree invariants", "kind": "concept", "parent": null, "description": "State what a subtree call returns and keep it true everywhere."}
